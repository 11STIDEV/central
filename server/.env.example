# Mesmo Client ID OAuth usado no frontend (VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=986687009371-051hostovvtrg4o478cuul2jq44a5iuv.apps.googleusercontent.com

# E-mail de um admin do Google Workspace (será usado como "subject" na chamada ao Admin SDK)
GOOGLE_ADMIN_IMPERSONATE=thiago.ferreira@portalcci.com.br

# Opção A: caminho para o arquivo JSON da chave (recomendado; não commitar o arquivo)
# GOOGLE_SERVICE_ACCOUNT_PATH=./service-account-key.json

# Opção B: conteúdo completo do JSON da service account (uma linha)
# Crie em: Google Cloud Console > APIs & Services > Credentials > Create Service Account
# Habilite Domain-Wide Delegation; no Admin do Google autorize o Client ID com os escopos:
#   https://www.googleapis.com/auth/admin.directory.user.readonly
#   https://www.googleapis.com/auth/admin.directory.device.chromeos
# (O escopo sem .readonly é necessário para disable/reenable nos Chromebooks.)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# (Opcional) Só Chromebooks desta OU — listagem na Agenda e worker (disable/reenable). Ex.: testes em Setape.
# GOOGLE_CHROMEBOOK_ORG_UNIT=/Administrativo/Setape

# Agenda CCI — bloqueio físico (Google Admin): desativa aparelhos fora da janela de reserva
# AGENDA_CCI_ENFORCE_DISABLE=true
# AGENDA_CCI_POLL_MS=60000
# AGENDA_CCI_TIMEZONE=America/Sao_Paulo
# Se true: com lista de reservas vazia, desativa todo o parque. Se false (padrão): só reativa quem estiver desativado (recuperação).
# AGENDA_CCI_DISABLE_WHEN_EMPTY=false

# Domínios de e-mail permitidos na API (separados por vírgula). Legado: DOMINIO_PERMITIDO com um único valor.
DOMINIOS_PERMITIDOS=@portalcci.com.br,@faculdadecci.com.br,@tecscci.com.br

# Porta da API (padrão: 3001)
PORT=3001

# Bind do Express (padrão: 0.0.0.0 — necessário em Docker; só use 127.0.0.1 se quiser só local)
# HOST=0.0.0.0

# Painel de senhas — criação de usuários (service role; não exponha no frontend)
# SUPABASE_URL=https://supabase.portalcci.com.br
# SUPABASE_SERVICE_ROLE_KEY=
